{
  "name": "marp-preview",
  "version": "1.0.0",
  "description": "A simple desktop app to preview Marp markdown files in real-time.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "test": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "marp",
    "markdown",
    "preview"
  ],
  "author": {
    "name": "Masanori Kado",
    "email": "kdmsnr@gmail.com",
    "url": "https://kdmsnr.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@marp-team/marp-cli": "^4.3.1",
    "@marp-team/marp-core": "^4.3.0",
    "@marp-team/marpit": "^3.2.1",
    "chokidar": "^5.0.0",
    "markdown-it-footnote": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.8.3"
  },
  "build": {
    "appId": "com.kdmsnr.marp-preview",
    "productName": "Marp Preview",
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "asarUnpack": [
      "node_modules/@marp-team/marp-cli/**",
      "node_modules/puppeteer/**"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "app/**/*.js"
    ]
  }
}
